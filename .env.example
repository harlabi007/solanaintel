# ─────────────────────────────────────────
# SOLANA INTEL — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Helius API — https://helius.dev (free tier available)
# Used for: real-time transactions, wallet history, token metadata
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API — https://birdeye.so/developer (free tier available)
# Used for: new listings, token prices, market data, trending tokens
BIRDEYE_API_KEY=your_birdeye_api_key_here

# RugCheck API — https://rugcheck.xyz (free, no key needed for basic)
# Used for: token safety scores, mint/freeze authority, LP lock status
# Leave blank to use public endpoint
RUGCHECK_API_KEY=

# Server config
PORT=3001

# Frontend URL (for CORS — set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000

# How often to poll for new data (milliseconds)
POLL_INTERVAL_MS=15000

# Minimum USD value to count as a whale transaction
WHALE_THRESHOLD_USD=50000

# Minimum USD value to count as an insider transaction
INSIDER_THRESHOLD_USD=1000
